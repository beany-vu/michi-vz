{
  "name": "michi-vz",
  "version": "0.6.15",
  "description": "A React + D3 chart library: ready-made line, area, bar, radar, and scatter charts with shared theming.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "homepage": "https://github.com/beany-vu/michi-vz#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/beany-vu/michi-vz.git"
  },
  "bugs": {
    "url": "https://github.com/beany-vu/michi-vz/issues"
  },
  "keywords": [
    "react",
    "d3",
    "charts",
    "visualization",
    "typescript",
    "data-viz"
  ],
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "serve-storybook": "npm run build-storybook && http-server storybook-static -p 6007 -s -c-1",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots",
    "build": "node node_modules/typescript/bin/tsc --pretty && node node_modules/tsc-alias/dist/bin/index.js",
    "build:to-thd": "npm run build && rm -rf /mnt/c/Coding/thd/frontend/node_modules/michi-vz/dist && cp -r ./dist /mnt/c/Coding/thd/frontend/node_modules/michi-vz/dist && echo '✓ michi-vz dist copied to thd/frontend/node_modules. Restart the dev server to pick it up.'",
    "build:files": "node node_modules/typescript/bin/tsc --pretty --listFiles && node node_modules/tsc-alias/dist/bin/index.js",
    "build:debug": "node node_modules/typescript/bin/tsc --pretty --extendedDiagnostics && node node_modules/tsc-alias/dist/bin/index.js",
    "build:trace": "node node_modules/typescript/bin/tsc --pretty --traceResolution && node node_modules/tsc-alias/dist/bin/index.js",
    "type-check": "node node_modules/typescript/bin/tsc --noEmit --pretty",
    "lint": "eslint './src/**/*.{ts,tsx}'",
    "lint:fix": "eslint './src/**/*.{ts,tsx}' --fix",
    "prepublishOnly": "npm run build",
    "deploy": "node node_modules/gh-pages/bin/gh-pages.js -d storybook-static"
  },
  "author": "Hoang VQ",
  "license": "ISC",
  "dependencies": {
    "d3": "^7.9.0",
    "d3-scale": "^4.0.2",
    "date-fns": "^4.1.0",
    "dompurify": "^3.4.5",
    "lodash": "^4.17.21",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "styled-components": "^6.1.8",
    "use-deep-compare-effect": "^1.8.1"
  },
  "devDependencies": {
    "@babel/core": "^7.23.9",
    "@babel/preset-env": "^7.23.9",
    "@babel/preset-react": "^7.23.9",
    "@babel/preset-typescript": "^7.23.9",
    "@playwright/test": "^1.60.0",
    "@storybook/addon-docs": "^10.4.1",
    "@storybook/addon-links": "^10.4.1",
    "@storybook/addon-webpack5-compiler-babel": "^4.0.1",
    "@storybook/cli": "^10.4.1",
    "@storybook/react": "^10.4.1",
    "@storybook/react-webpack5": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/d3": "^7.4.3",
    "@types/jest": "^29.5.12",
    "@types/lodash": "^4.17.24",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.2",
    "@typescript-eslint/eslint-plugin": "^6.1.0",
    "@typescript-eslint/parser": "^6.1.0",
    "babel-jest": "^29.7.0",
    "eslint": "^8.56.0",
    "eslint-config-airbnb-typescript": "^17.1.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-storybook": "^10.4.1",
    "gh-pages": "^6.3.0",
    "http-server": "^14.1.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.2.5",
    "storybook": "^10.4.1",
    "ts-jest": "^29.1.2",
    "tsc-alias": "^1.8.16",
    "typescript": "^6.0.3"
  },
  "moduleNameMapper": {
    "^src/(.*)$": "<rootDir>/src/$1"
  }
}
